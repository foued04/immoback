PORT=5000
NODE_ENV=development

# MongoDB connection string
# Local example: mongodb://127.0.0.1:27017/immosmart
# Atlas example: mongodb+srv://USERNAME:PASSWORD@cluster-name.xxxxx.mongodb.net/immosmart?retryWrites=true&w=majority
MONGO_URI=mongodb://127.0.0.1:27017/immosmart

# Optional: one-time Atlas import source
ATLAS_MONGO_URI=

# Security
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=15m
ADMIN_SECRET=change-this-admin-secret

# Email
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
EMAIL_FROM=your-email@example.com

# Frontend
FRONTEND_URL=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
